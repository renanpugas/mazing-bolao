{
  "name": "server",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.mjs",
    "test:e2e": "vitest run --config vitest.e2e.config.ts"
  },
  "dependencies": {
    "@mazing-bolao/api": "workspace:*",
    "@mazing-bolao/auth": "workspace:*",
    "@mazing-bolao/db": "workspace:*",
    "@mazing-bolao/env": "workspace:*",
    "@orpc/openapi": "catalog:",
    "@orpc/server": "catalog:",
    "@orpc/zod": "catalog:",
    "better-auth": "catalog:",
    "cors": "^2.8.5",
    "dotenv": "catalog:",
    "express": "^5.1.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@libsql/client": "0.15.15",
    "@mazing-bolao/config": "workspace:*",
    "@types/cors": "^2.8.17",
    "@types/express": "catalog:",
    "@types/node": "catalog:",
    "@types/supertest": "^6.0.3",
    "drizzle-orm": "^0.45.1",
    "supertest": "^7.1.1",
    "tsdown": "^0.21.9",
    "tsx": "^4.19.2",
    "typescript": "catalog:",
    "vitest": "^4.0.8"
  }
}
