{
  "name": "@mazing-bolao/db",
  "type": "module",
  "exports": {
    ".": {
      "default": "./src/index.ts"
    },
    "./*": {
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "db:local": "turso dev --db-file local.db",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "node src/seed.mjs && node src/seed-odds-api-match-ids.mjs && node src/seed-match-odds-values.mjs",
    "db:seed:odds-api-match-ids": "node src/seed-odds-api-match-ids.mjs",
    "db:seed:match-odds-values": "node src/seed-match-odds-values.mjs",
    "db:setup": "drizzle-kit migrate && pnpm db:seed"
  },
  "dependencies": {
    "@libsql/client": "0.15.15",
    "@mazing-bolao/env": "workspace:*",
    "dotenv": "catalog:",
    "drizzle-orm": "^0.45.1",
    "libsql": "0.5.22",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@mazing-bolao/config": "workspace:*",
    "drizzle-kit": "^0.31.8",
    "typescript": "catalog:"
  }
}
